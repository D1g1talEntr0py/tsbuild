{
  "name": "@d1g1tal/tsbuild",
  "author": "D1g1talEntr0py",
  "version": "2.0.0",
  "license": "MIT",
  "description": "A fast, ESM-only TypeScript build tool combining the TypeScript API for type checking and declaration generation with esbuild for bundling. Built for modern ESM-only projects on Node.js 22+.",
  "homepage": "https://github.com/D1g1talEntr0py/tsbuild#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D1g1talEntr0py/tsbuild.git"
  },
  "bugs": {
    "url": "https://github.com/D1g1talEntr0py/tsbuild/issues"
  },
  "maintainers": [
    {
      "name": "D1g1talEntr0py",
      "email": "jason.dimeo@gmail.com"
    }
  ],
  "engines": {
    "node": ">=22.6.0"
  },
  "packageManager": "pnpm@11.8.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "types": "./dist/type-script-project.d.ts",
  "exports": {
    ".": {
      "types": "./dist/type-script-project.d.ts",
      "import": "./dist/type-script-project.js"
    }
  },
  "files": [
    "./dist",
    "./schema.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "tsbuild": "./dist/tsbuild.js"
  },
  "scripts": {
    "build": "node --experimental-strip-types ./scripts/loader.ts ./src/tsbuild.ts",
    "build:watch": "node --experimental-strip-types ./scripts/loader.ts ./src/tsbuild.ts --watch",
    "bench": "node --experimental-strip-types ./scripts/loader.ts ./tests/scripts/benchmark.ts",
    "type-check": "node --experimental-strip-types ./scripts/loader.ts ./src/tsbuild.ts --noEmit",
    "lint": "eslint ./src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:compat": "node --experimental-strip-types ./scripts/loader.ts tests/scripts/test-ts-compat.ts --versions 5"
  },
  "dependencies": {
    "@d1g1tal/watchr": "^1.0.6",
    "esbuild": "^0.28.1",
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-jsdoc": "^63.0.6",
    "fs-monkey": "^1.1.0",
    "memfs": "^4.57.7",
    "mitata": "^1.0.34",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typescript": ">=5.6.3"
  },
  "keywords": [
    "typescript",
    "build",
    "bundler",
    "compiler",
    "type-checking",
    "library",
    "esbuild",
    "declarations",
    "dts",
    "esm"
  ]
}
