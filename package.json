{
  "name": "@d1g1tal/tsbuild",
  "author": "D1g1talEntr0py",
  "version": "1.6.0",
  "license": "MIT",
  "description": "A fast, ESM-only TypeScript build tool combining the TypeScript API for type checking and declaration generation, esbuild for bundling, and SWC for decorator metadata.",
  "homepage": "https://github.com/D1g1talEntr0py/tsbuild#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D1g1talEntr0py/tsbuild.git"
  },
  "bugs": {
    "url": "https://github.com/D1g1talEntr0py/tsbuild/issues"
  },
  "maintainers": [
    {
      "name": "D1g1talEntr0py",
      "email": "jason.dimeo@gmail.com"
    }
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.32.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "./dist",
    "./schema.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "tsbuild": "./dist/tsbuild.js"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "tsx ./src/tsbuild.ts",
    "build:watch": "tsx ./src/tsbuild.ts --watch",
    "type-check": "tsx ./src/tsbuild.ts --noEmit",
    "lint": "eslint ./src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@d1g1tal/watchr": "^1.0.3",
    "esbuild": "^0.27.4",
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-jsdoc": "^62.8.0",
    "fs-monkey": "^1.1.0",
    "memfs": "^4.56.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "typescript",
    "build",
    "bundler",
    "esbuild",
    "declarations",
    "dts",
    "esm"
  ]
}
