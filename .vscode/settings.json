{
	"json.schemas": [

		{
			"url": "./schema.json",
			"fileMatch": [ "/tsconfig.json", "/package.json" ]
		}
	],
	"editor.formatOnSave": false,
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "never"
	},
	"cSpell.words": [
		"Arpad",
		"Borsos"
	],
	"js/ts.tsdk.path": "node_modules/typescript/lib"
}